	<script type="text/javascript">		

		$('#form').on('click', (e) => {
    		e.preventDefault();
		});

        $("a.go[href*='#']").on("click", function(e){           		
        	var anchor = $(this);
            $('html, body').stop().animate({
            	scrollTop: $(anchor.attr('href')).offset().top
            }, 777); //как будто проматываем наверх, но мотается до якоря
            e.preventDefault();
            return false;
        });

		var min = Number($(".min").text());
			var sec = Number($(".sec").text());
			var _Seconds = (min * 60) + sec; //узнаём общее количество секунд для интервала
			var int;

  		int = setInterval(function() { // запускаем интервал
			var min = Number($(".min").text());
			var sec = Number($(".sec").text());

  			if (_Seconds > 0) {
    			_Seconds--; // вычитаем 1
    			if (sec != 0) { //если поле секунд больше 0 то делаем следующеии
    				if (sec <= 9) { // для того что бы отображалось вот так '03', делаем небольшую проверку
    					$(".sec").text('0' + (sec - 1));
    				} else {
    					$(".sec").text(sec - 1);
    				}    				
    			} else {
    				if (min != 0) { // если поле секунд ровно 0, проверяем на то же самое поле минут
    					if (min <= 9) { //такая же проверка для поля минут на отображение '03'
    						$(".min").text('0' + (min - 1));
    						$(".sec").text(59);
    					} else {
    						$(".min").text(min - 1);
    						$(".sec").text(59);
    					}    					
    				}
    			}
  			} else { //если общее количество секунд столо равно 0, заканчиваем интервал
    			clearInterval(int);
    			alert('Усё!');
  			}
		}, 1000);
	</script>
